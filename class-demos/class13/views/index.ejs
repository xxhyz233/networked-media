<html>
  <head>
    <title>class 13 starter</title>
    <link href="style.css" rel="stylesheet">
  </head>
  <body>
      <form method="POST" action="/upload" enctype="multipart/form-data">
          <input type="text" name="text" placeholder="Say something..." />
          <div class="submit-container">
            <div>
              <label for="file-upload" class="custom-file-upload"> </label>
              <input id="file-upload" name="theimage" type="file" />
            </div>
            <div>
              <input type="submit" name="submitbutton" value="Submit" />
            </div>
          </div>
      </form>
    <div class="all-posts">
      <!-- add the variable that stores your global array in response.render) -->
        <% for(let post of posts) { %>
        <div class="post">
          <%# what is the difference between <%= %> and <% %> ? #%>
          <%# A: <%= %> references a variable while <% %> executes a JS code #%>
            <span class="date"> <%= post.date %></span>
            <% if(post.image) { %>
                <img src="<%=post.image %>">
            <% } %>
            <p class="post-text"><%= post.text %></p>
        </div>
        <% } %>
      </div>
  </body>
</html>
